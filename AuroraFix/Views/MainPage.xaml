<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:AuroraFix.ViewModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="AuroraFix.Views.MainPage"
             BackgroundColor="{StaticResource BackgroundDark}"
             Shell.NavBarIsVisible="False">

    <Grid>
        <!--Background aurora gif-->
        <Image Source="giphy.gif"
               Aspect="AspectFill"
               Opacity="0.5"
               IsAnimationPlaying="True" />
        <BoxView>
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#E6050810" Offset="0.0" />
                    <GradientStop Color="Transparent" Offset="0.4" />
                    <GradientStop Color="#FF050810" Offset="0.9" />
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <!--Main content-->
        <ScrollView VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Padding="30,25,30,20" Spacing="40">

                <!--App title-->
                <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                    <Label Text="AURORA FORECAST"
                           CharacterSpacing="6"
                           FontSize="{StaticResource FontSizeAppTitle}"
                           TextColor="{StaticResource AuroraTeal}"
                           HorizontalTextAlignment="Center"
                           HorizontalOptions="Center"
                           FontFamily="MontserratBold"/>
                </VerticalStackLayout>

                <!--City search-->
                <Grid ColumnDefinitions="*, Auto" Margin="10,0">
                    <Border Stroke="{StaticResource SearchBorder}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 8">
                        <Entry x:Name="CityEntry"
                               Text="{Binding CityName}"
                               Placeholder="Search location..."
                               PlaceholderColor="{StaticResource TextMuted}"
                               TextColor="White"
                               FontFamily="Montserrat"
                               FontSize="{StaticResource FontSizeBodyLarge}"
                               BackgroundColor="Transparent"
                               IsSpellCheckEnabled="False"
                               IsTextPredictionEnabled="False"
                               Completed="OnSearchClicked" />
                    </Border>
                    <Button Grid.Column="1"
                            Text="GO"
                            Margin="10,0,0,0"
                            Command="{Binding SearchCityCommand}"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource AuroraTeal}"
                            FontFamily="MontserratBold"
                            FontSize="{StaticResource FontSizeCaption}"
                            Padding="15,0" />
                </Grid>

                <!--Probability ring-->
                <Grid HeightRequest="300" WidthRequest="300"
                      HorizontalOptions="Center" IsVisible="{Binding IsDataLoaded}"
                      Margin="0,0,0,-30">
                    <Path Stroke="#20FFFFFF"
                          StrokeThickness="12"
                          StrokeLineCap="Round">
                        <Path.Data>
                            <PathGeometry>
                                <PathFigure StartPoint="140,10">
                                    <ArcSegment Point="139.9,10"
                                                Size="130,130"
                                                IsLargeArc="True"
                                                SweepDirection="Clockwise" />
                                </PathFigure>
                            </PathGeometry>
                        </Path.Data>
                    </Path>
                    <Path Stroke="{StaticResource AuroraTeal}"
                          StrokeThickness="12"
                          StrokeLineCap="Round"
                          StrokeDashArray="{Binding StrokeDashValues}">
                        <Path.Data>
                            <PathGeometry>
                                <PathFigure StartPoint="140,10">
                                    <ArcSegment Point="139.9,10"
                                                Size="130,130"
                                                IsLargeArc="True"
                                                SweepDirection="Clockwise" />
                                </PathFigure>
                            </PathGeometry>
                        </Path.Data>
                    </Path>

                    <VerticalStackLayout VerticalOptions="Center"
                                         HorizontalOptions="Center"
                                         Margin="-10,3,0,0">
                        <Label Text="PROBABILITY"
                               FontSize="{StaticResource FontSizeLabel}"
                               TextColor="{StaticResource TextSubtle}"
                               HorizontalOptions="Center"
                               CharacterSpacing="4"
                               FontFamily="Montserrat"/>
                        <Label Text="{Binding Probability, StringFormat='{0:F0}%'}"
                               FontSize="{StaticResource FontSizeProbabilityHuge}"
                               TextColor="White"
                               FontFamily="MontserratBold"
                               HorizontalOptions="Center">
                            <Label.Shadow>
                                <Shadow Brush="{StaticResource AuroraTeal}" Offset="0,0" Radius="30" Opacity="0.6" />
                            </Label.Shadow>
                        </Label>
                        <Label Text="{Binding ActivityLevel}"
                               FontSize="{StaticResource FontSizeActivityLevel}"
                               HorizontalOptions="Center"
                               TextColor="{StaticResource AuroraTeal}"
                               Margin="0,-20,0,0"/>
                        <Label Text="KP INDEX: "
                               FontSize="{StaticResource FontSizeLabel}"
                               HorizontalOptions="Center"
                               TextColor="Gray"
                               Margin="0,5,0,0"/>
                        <Label Text="{Binding CurrentKpIndex, StringFormat='{0:F1}'}"
                               FontSize="{StaticResource FontSizeLabel}"
                               HorizontalOptions="Center"
                               TextColor="{StaticResource AuroraTeal}"/>
                    </VerticalStackLayout>
                </Grid>

                <!--Conditions description card-->
                <Border StrokeShape="RoundRectangle 25"
                        BackgroundColor="{StaticResource CardBackground}"
                        Padding="25,20"
                        Stroke="Transparent">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="MORE"
                               FontSize="{StaticResource FontSizeCaption}"
                               TextColor="{StaticResource TextMuted}"
                               HorizontalOptions="Center"
                               CharacterSpacing="3"
                               FontFamily="Montserrat"/>
                        <Label Text="{Binding ActivityDescription}"
                               FontSize="{StaticResource FontSizeBody}"
                               TextColor="White"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="WordWrap"
                               FontFamily="Montserrat"
                               LineHeight="1.2"/>
                    </VerticalStackLayout>
                </Border>

                <!--3-day forecast-->
                <VerticalStackLayout Spacing="20" IsVisible="{Binding IsDataLoaded}">
                    <Label Text="3-DAY FORECAST"
                           FontSize="{StaticResource FontSizeCaption}"
                           CharacterSpacing="3"
                           TextColor="{StaticResource TextMuted}"
                           Margin="5,0"
                           FontFamily="MontserratBold"/>

                    <CollectionView ItemsSource="{Binding ThreeDayForecast}"
                                    >
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="50, *, Auto"
                                      RowDefinitions="Auto, 1"
                                      Padding="10,20">
                                    <Label Text="{Binding IconEmoji}"
                                           FontSize="{StaticResource FontSizeForecastIcon}"
                                           VerticalOptions="Center" />
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Margin="15,0">
                                        <Label Text="{Binding Date}"
                                               TextColor="White"
                                               FontFamily="MontserratBold"
                                               FontSize="{StaticResource FontSizeForecastDay}" />
                                        <Label Text="{Binding KpIndex, StringFormat='KP INDEX: {0:F1}'}"
                                               FontSize="{StaticResource FontSizeForecastDay}"
                                               TextColor="{StaticResource AuroraTeal}"
                                               FontFamily="Montserrat"
                                               Opacity="0.7"/>
                                        <Label Text="{Binding DarknessWindow}"
                                               FontSize="{StaticResource FontSizeDarknessWindow}"
                                               TextColor="{StaticResource TextMuted}"
                                               FontFamily="Montserrat">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding DarknessWindow}" Value="">
                                                    <Setter Property="IsVisible" Value="False" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </VerticalStackLayout>
                                    <Label Grid.Column="2"
                                           Text="{Binding Probability, StringFormat='{0:F0}%'}"
                                           TextColor="{StaticResource AuroraTeal}"
                                           FontSize="{StaticResource FontSizeForecastProb}"
                                           FontFamily="MontserratBold"
                                           VerticalOptions="Center" />
                                    <BoxView Grid.Row="1" Grid.ColumnSpan="3"
                                             HeightRequest="0.5"
                                             Color="{StaticResource DividerLine}"
                                             VerticalOptions="End" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!--Source attribution-->
                <Label Text="SOURCE: NOAA SPACE WEATHER"
                       FontSize="{StaticResource FontSizeFooter}"
                       TextColor="{StaticResource TextVeryMuted}"
                       FontFamily="Montserrat"
                       HorizontalOptions="Center"
                       Margin="0,20"/>

            </VerticalStackLayout>
        </ScrollView>

        <!--Loading overlay-->
        <Grid IsVisible="{Binding IsBusy}" BackgroundColor="{StaticResource LoadingOverlay}">
            <ActivityIndicator IsRunning="True"
                               Color="{StaticResource AuroraTeal}"
                               WidthRequest="50"
                               HeightRequest="50"
                               VerticalOptions="Center"
                               HorizontalOptions="Center" />
        </Grid>
    </Grid>
</ContentPage>
